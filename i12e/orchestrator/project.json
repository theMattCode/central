{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "i12e-orchestrator",
  "projectType": "application",
  "root": "i12e/orchestrator",
  "sourceRoot": "i12e/orchestrator",
  "targets": {
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "sh -n i12e/orchestrator/scripts/up_stack.sh && docker compose --env-file i12e/orchestrator/.env.dev --file i12e/orchestrator/docker-compose.yml config --quiet"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker compose --env-file i12e/orchestrator/.env.prod --file i12e/orchestrator/docker-compose.yml config --quiet"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker compose --env-file i12e/orchestrator/.env.dev --file i12e/orchestrator/docker-compose.yml config --quiet"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "sh -n i12e/orchestrator/scripts/up_stack.sh && docker compose --env-file i12e/orchestrator/.env.prod --file i12e/orchestrator/docker-compose.yml config --quiet"
      }
    },
    "up-dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "sh i12e/orchestrator/scripts/up_stack.sh dev full"
      }
    },
    "up-dev-llm-proxy-ollama": {
      "executor": "nx:run-commands",
      "options": {
        "command": "sh i12e/orchestrator/scripts/up_stack.sh dev llm-proxy-ollama"
      }
    },
    "smoke-dev-voice": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm nx run i12e-orchestrator:up-dev && python3 i12e/orchestrator/scripts/smoke_voice.py"
      }
    },
    "up-prod": {
      "executor": "nx:run-commands",
      "options": {
        "command": "sh i12e/orchestrator/scripts/up_stack.sh prod full"
      }
    },
    "down-dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker compose --env-file i12e/orchestrator/.env.dev --file i12e/orchestrator/docker-compose.yml down --remove-orphans"
      }
    },
    "down-prod": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker compose --env-file i12e/orchestrator/.env.prod --file i12e/orchestrator/docker-compose.yml down --remove-orphans"
      }
    },
    "migrate-dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker compose --env-file i12e/orchestrator/.env.dev --file i12e/orchestrator/docker-compose.yml run --rm --no-deps i12e-postgres-migrate"
      }
    },
    "migrate-prod": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker compose --env-file i12e/orchestrator/.env.prod --file i12e/orchestrator/docker-compose.yml run --rm --no-deps i12e-postgres-migrate"
      }
    },
    "logs-dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker compose --env-file i12e/orchestrator/.env.dev --file i12e/orchestrator/docker-compose.yml logs --follow --tail=100"
      }
    },
    "logs-prod": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker compose --env-file i12e/orchestrator/.env.prod --file i12e/orchestrator/docker-compose.yml logs --follow --tail=100"
      }
    },
    "ps-dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker compose --env-file i12e/orchestrator/.env.dev --file i12e/orchestrator/docker-compose.yml ps"
      }
    },
    "ps-prod": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker compose --env-file i12e/orchestrator/.env.prod --file i12e/orchestrator/docker-compose.yml ps"
      }
    }
  },
  "tags": ["scope:platform", "type:infra"]
}
