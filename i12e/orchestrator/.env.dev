COMPOSE_PROJECT_NAME=central-i12e-dev
COCKPIT_PORT=3000
COCKPIT_NODE_ENV=development
POSTGRES_PORT=3001
WEATHER_PORT=3010
WEATHER_SERVICE_BASE_URL=http://service-weather:8080
WEATHER_CORS_ALLOW_ORIGIN=*
WEATHER_DATABASE_URL=postgres://central:central@i12e-postgres:5432/central

VOICE_PORT=3020
VOICE_SERVICE_BASE_URL=http://service-voice:8080
VOICE_CORS_ALLOW_ORIGIN=*

VOICE_BACKEND_MODE=proxy
VOICE_REQUEST_TIMEOUT_SECONDS=120
VOICE_TTS_STREAM_SOFT_LIMIT_CHARS=220
VOICE_STT_URL=http://service-voice-local-stt:8081/transcribe
VOICE_TTS_URL=http://service-voice-local-tts:8082/synthesize
VOICE_LLM_BASE_URL=http://service-voice-local-llm:8083
VOICE_LLM_MODEL=qwen3.5:9b
VOICE_LOCAL_LLM_MODEL=qwen3.5:9b
VOICE_LOCAL_LLM_KEEP_ALIVE=30m
VOICE_LOCAL_STT_MODEL=medium
VOICE_LOCAL_STT_BEAM_SIZE=7
VOICE_LOCAL_STT_VAD_FILTER=false
VOICE_LOCAL_TTS_SENTENCE_SILENCE=0.12
VOICE_LOCAL_TTS_VOLUME=1.05
#VOICE_LLM_MODEL=qwen2.5:3b
#VOICE_LOCAL_TTS_MODEL=de_DE-thorsten-high
VOICE_DEFAULT_VOICE_INSTRUCTION=Tiefe, warme, deutsche, männliche Stimme. Sprich klar, freundlich und eher knapp.

#VOICE_BACKEND_MODE=openai
#VOICE_LLM_BASE_URL=
#VOICE_LLM_API_KEY=
#VOICE_LLM_MODEL=gpt-5-nano
#VOICE_STT_MODEL=gpt-4o-mini-transcribe
#VOICE_TTS_MODEL=gpt-4o-mini-tts
#VOICE_TTS_VOICE=alloy
