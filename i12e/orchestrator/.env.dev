COMPOSE_PROJECT_NAME=central-i12e-dev
COCKPIT_PORT=3000
COCKPIT_NODE_ENV=development
POSTGRES_PORT=3001
WEATHER_PORT=3010
WEATHER_SERVICE_BASE_URL=http://service-weather:8080
WEATHER_CORS_ALLOW_ORIGIN=*
WEATHER_DATABASE_URL=postgres://central:central@i12e-postgres:5432/central

ASSISTANT_PORT=3020
ASSISTANT_SERVICE_BASE_URL=http://service-assistant:8080
ASSISTANT_CORS_ALLOW_ORIGIN=*

ASSISTANT_BACKEND_MODE=proxy
ASSISTANT_REQUEST_TIMEOUT_SECONDS=120

LLM_BASE_URL=http://service-llm:8083
LLM_MODEL=qwen3.5:4b
#LLM_MODEL=qwen3.5:9b
#LLM_MODEL=qwen2.5:3b

LLM_KEEP_ALIVE=30m

STT_URL=http://service-stt:8081/transcribe
STT_MODEL=medium
STT_BEAM_SIZE=7
STT_VAD_FILTER=false

TTS_URL=http://service-tts:8082/synthesize
TTS_STREAM_SOFT_LIMIT_CHARS=220
#TTS_MODEL=de_DE-thorsten-medium
#TTS_MODEL=de_DE-thorsten-high
TTS_SENTENCE_SILENCE=0.12
TTS_VOLUME=1.05

ASSISTANT_DEFAULT_VOICE_INSTRUCTION=Tiefe, warme, deutsche, männliche Stimme. Sprich klar, freundlich und eher knapp.

#ASSISTANT_BACKEND_MODE=openai
#LLM_BASE_URL=
#LLM_API_KEY=
#LLM_MODEL=gpt-5-nano
#STT_MODEL=gpt-4o-mini-transcribe
#TTS_MODEL=gpt-4o-mini-tts
#TTS_VOICE=alloy
