COMPOSE_PROJECT_NAME=central-i12e-prod
COCKPIT_PORT=4000
COCKPIT_NODE_ENV=production
POSTGRES_PORT=4001
BACKEND_PORT=4010
BACKEND_BASE_URL=http://service-backend:8080
BACKEND_CORS_ALLOW_ORIGIN=*
BACKEND_DATABASE_URL=postgres://central:central@i12e-postgres:5432/central
WEATHER_REFRESH_INTERVAL_SECONDS=900
WEATHER_REQUEST_TIMEOUT_SECONDS=10
WEATHER_OPEN_METEO_BASE_URL=https://api.open-meteo.com

ASSISTANT_PORT=4020
STT_PORT=4030
TTS_PORT=4040
LLM_PORT=4050
LLM_RUNTIME_PORT=4051
ASSISTANT_SERVICE_BASE_URL=http://service-assistant:8080
ASSISTANT_CORS_ALLOW_ORIGIN=*

ASSISTANT_BACKEND_MODE=proxy
ASSISTANT_REQUEST_TIMEOUT_SECONDS=120
STT_URL=http://service-stt:8081/transcribe
TTS_URL=http://service-tts:8082/synthesize
TTS_MODEL=Qwen/Qwen3-TTS-12Hz-1.7B-Base
TTS_REFERENCE_AUDIO=/app/res/morgan-freeman.mp3
TTS_REFERENCE_TEXT_FILE=/app/res/morgan-freeman.txt
TTS_REFERENCE_TEXT=
TTS_X_VECTOR_ONLY_MODE=false
TTS_DEVICE_MAP=cuda:0
TTS_DTYPE=bfloat16
TTS_ATTENTION_IMPLEMENTATION=flash_attention_2
LLM_BASE_URL=http://service-llm:8083
LLM_MODEL=qwen3:8b
#LLM_MODEL=qwen2.5:3b
ASSISTANT_DEFAULT_VOICE_INSTRUCTION=Tiefe, warme, deutsche, männliche Stimme. Sprich klar, freundlich und eher knapp.
