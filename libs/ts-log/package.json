{
  "name": "@central/ts-log",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": {
      "@central/source": "./src/*",
      "types": "./src/*",
      "default": "./src/*"
    }
  },
  "exports": {
    ".": {
      "@central/source": "./src/index.ts",
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./src/*": {
      "@central/source": "./src/*",
      "types": "./src/*",
      "default": "./src/*"
    }
  },
  "devDependencies": {
    "vitest": "4.0.18"
  }
}
