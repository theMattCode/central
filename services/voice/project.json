{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "voice-service",
  "projectType": "application",
  "root": "services/voice",
  "sourceRoot": "services/voice/src",
  "targets": {
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "services/voice",
        "command": "cargo clippy --all-targets --all-features -- -D warnings"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "services/voice",
        "command": "cargo test --all-targets"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "services/voice",
        "command": "cargo build --release"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "services/voice",
        "command": "cargo check --all-targets"
      }
    },
    "container-build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker build --file services/voice/Dockerfile --tag central/services/voice:latest ."
      }
    },
    "container-run": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker run --rm -i --name central-voice -p 5020:8080 central/services/voice:latest"
      }
    }
  },
  "tags": ["scope:platform", "type:service"]
}
