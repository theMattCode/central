{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "cockpit",
  "projectType": "application",
  "root": "apps/cockpit",
  "sourceRoot": "apps/cockpit/src",
  "targets": {
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/cockpit",
        "command": "pnpm run start:dev"
      }
    },
    "preview": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/cockpit",
        "command": "pnpm run start:preview"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "cwd": "apps/cockpit",
        "command": "pnpm run build"
      }
    },
    "container-build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker build --build-arg VITE_WEATHER_API_BASE_URL=${VITE_WEATHER_API_BASE_URL:-http://localhost:5010} --file apps/cockpit/Dockerfile --tag central/apps/cockpit:latest ."
      }
    },
    "container-run": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker run --rm --name central-cockpit -p 5000:3000 central/apps/cockpit:latest"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/cockpit",
        "command": "pnpm exec vitest run --passWithNoTests"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/cockpit",
        "command": "pnpm exec tsc --noEmit -p tsconfig.json"
      }
    }
  },
  "tags": []
}
