{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "cockpit",
  "projectType": "application",
  "root": "apps/cockpit",
  "sourceRoot": "apps/cockpit/src",
  "targets": {
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/cockpit",
        "command": "pnpm exec prettier --check \"src/components/**/*.{ts,tsx}\" \"src/widgets/**/*.{ts,tsx}\" \"src/utils/**/*.ts\" \"src/routes/**/*.tsx\" \"src/styles.css\" \"src/i18n/**/*.ts\" \"src/router.tsx\""
      }
    },
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/cockpit",
        "command": "pnpm run start:dev"
      }
    },
    "preview": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/cockpit",
        "command": "pnpm run start:preview"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "cwd": "apps/cockpit",
        "command": "pnpm run build"
      }
    },
    "container-build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker build --build-arg WEATHER_SERVICE_BASE_URL=${WEATHER_SERVICE_BASE_URL:-http://host.docker.internal:5010} --build-arg VOICE_SERVICE_BASE_URL=${VOICE_SERVICE_BASE_URL:-http://host.docker.internal:5020} --build-arg VITE_WEATHER_API_BASE_URL=${VITE_WEATHER_API_BASE_URL:-http://localhost:5010} --build-arg VITE_VOICE_API_BASE_URL=${VITE_VOICE_API_BASE_URL:-http://localhost:5020} --file apps/cockpit/Dockerfile --tag central/apps/cockpit:latest ."
      }
    },
    "container-run": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker run --rm --name central-cockpit --add-host=host.docker.internal:host-gateway -e WEATHER_SERVICE_BASE_URL=${WEATHER_SERVICE_BASE_URL:-http://host.docker.internal:5010} -e VOICE_SERVICE_BASE_URL=${VOICE_SERVICE_BASE_URL:-http://host.docker.internal:5020} -p 5000:3000 central/apps/cockpit:latest"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/cockpit",
        "command": "pnpm run test -- --passWithNoTests"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/cockpit",
        "command": "pnpm run typecheck"
      }
    }
  },
  "tags": []
}
